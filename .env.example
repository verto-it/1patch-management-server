NODE_ENV=development
PORT=4100
PUBLIC_URL=https://manage.1patch.local
DATABASE_URL=postgres://1patch:1patch@localhost:5432/1patch_management
DRAGONFLY_URL=redis://localhost:6379
PACKAGE_STORAGE_PATH=./packages
JWT_SECRET=change-me-with-32-random-bytes
# Impossible-travel detection (opt-in). Set to the header your fronting proxy injects
# with the visitor's country (e.g. cf-ipcountry on Cloudflare for the hosted/SaaS mode).
# Leave unset for self-hosted deployments without a geo-aware proxy — the server then
# never trusts a client-supplied country.
# GEO_COUNTRY_HEADER=cf-ipcountry
MANAGEMENT_SIGNING_ACTIVE_KEY_ID=main
MANAGEMENT_SIGNING_PRIVATE_KEY=base64-encoded-pkcs8-p256-private-key-pem
MANAGEMENT_SIGNING_PUBLIC_KEYS_JSON={"main":"-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"}
FIRST_OWNER_EMAIL=owner@example.com
FIRST_OWNER_PASSWORD=ChangeMeNow!12345
# Vault PKI — required in production; server starts over plain HTTP without these (with a warning)
VAULT_ADDR=http://127.0.0.1:8200
VAULT_APPROLE_ROLE_ID=
VAULT_APPROLE_SECRET_ID=
TLS_CERT_PATH=C:\ProgramData\1Patch\tls\management.crt
TLS_KEY_PATH=C:\ProgramData\1Patch\tls\management.key
TLS_CA_PATH=C:\ProgramData\1Patch\tls\ca.crt
